# API base URL (Rails backend)
VITE_API_BASE_URL=http://localhost:3000

# Go face-search service
VITE_FACE_SEARCH_URL=http://localhost:8081
VITE_FACE_SEARCH_TOKEN=<shared-secret-with-face-search-service>

# Default admin credentials for local dev (Rails seeds creates this user)
VITE_ADMIN_EMAIL=admin@appperfil.cl
VITE_ADMIN_PASSWORD=<dev-admin-password>
