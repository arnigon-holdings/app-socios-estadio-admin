# =============================================================================
# admin/.env.example  —  Panel de Administración
# =============================================================================
# Copiar a .env.local (Vite solo lee .env / .env.local / .env.production).
# NUNCA commitear el archivo .env.local real.
# =============================================================================

# ---- Backend API (Rails) ----
VITE_API_BASE_URL=http://localhost:3001

# ---- Go face-search service (bypass Rails) ----
VITE_FACE_SEARCH_URL=http://localhost:8081
VITE_FACE_SEARCH_TOKEN=            # bearer token compartido con face-search-service

# ---- Credenciales admin dev (opcional, solo para UX placeholder) ----
# Estos valores SOLO se usan como placeholder en el form de login.
# La autenticación real la hace el backend contra la tabla `admins`.
# En producción, dejar vacíos (el form se renderiza sin sugerencias).
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=